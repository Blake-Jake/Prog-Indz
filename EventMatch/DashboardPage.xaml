<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EventMatch.DashboardPage"
             BackgroundImageSource="purplebackg.jpg"
             Title="DashboardPage">
    
    <VerticalStackLayout VerticalOptions="Center" Spacing="20" Margin="20" >
        <Label 
            Text="Welcome to EventMatch" TextColor="#A259FF" FontSize="20" FontAttributes="Bold"
            VerticalOptions="Center" 
            HorizontalOptions="Center"/>
        <Button Text="Start looking for events" BackgroundColor="#3CB371" TextColor="White" FontAttributes="Bold" Clicked="OnStartLookingClicked" />
        <Button Text="Events Map" BackgroundColor="#3CB371" TextColor="White" FontAttributes="Bold" Clicked="OnMapsClicked" />
        <Button Text="Profile" BackgroundColor="#A259FF" TextColor="White" FontAttributes="Bold" Clicked="OnOpenProfileClicked" />
        <Button Text="Create Event" BackgroundColor="#A259FF" TextColor="White" FontAttributes="Bold" Clicked="OnCreateEventClicked" />
        <Button Text="Logout" BackgroundColor="#9932CC" TextColor="White" FontAttributes="Bold" Command="{Binding LogoutCommand}" />
    </VerticalStackLayout>
</ContentPage>