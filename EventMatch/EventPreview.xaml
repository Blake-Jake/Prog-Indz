<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EventMatch.EventPreview"
             Title="ReviewEvents"
             BackgroundColor="#121212">

    <Grid>
        <Label Text="Event Preview" FontSize="20" TextColor="White" HorizontalOptions="Center" />
        <Image x:Name="EventImage"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Start"
               HeightRequest="350"/>

        <Border StrokeThickness="0"
                VerticalOptions="End"
                HeightRequest="400"
                StrokeShape="RoundRectangle 25,25,0,0"
                Padding="0">
            <Grid>
                <!-- FONAS -->
                <Image Source="download_p.jpg" Aspect="AspectFill"/>
                <!-- TAMSUS OVERLAY -->
                <BoxView BackgroundColor="#80232323"/>

                <!-- TURINYS -->
                <StackLayout Padding="20" Spacing="10">
                    <Label x:Name="NoEventsLabel"
                           Text="No events at the moment"
                           FontSize="16"
                           TextColor="White"
                           HorizontalOptions="Center"
                           IsVisible="False"/>

                    <Label Text="Event"
                           FontSize="20"
                           TextColor="White"
                           FontAttributes="Bold"/>

                    <Label x:Name="EventDetailsLabel"
                           TextColor="White"
                           FontSize="14"/>

                    <Label x:Name="CreatedAtLabel"
                           FontSize="12"
                           TextColor="#D8BFD8"
                           HorizontalOptions="End"/>
                </StackLayout>
            </Grid>
        </Border>

        <!-- X BUTTON -->
        <Button x:Name="CycleEventButton"
                Text="X"
                WidthRequest="44"
                HeightRequest="44"
                CornerRadius="22"
                BackgroundColor="#AA000000"
                TextColor="White"
                Clicked="OnCycleEventClicked"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="16"/>

        <!-- FAVORITE BUTTON -->
        <Button x:Name="FavoriteButton"
                Text="♥"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                BackgroundColor="#AA00AA00"
                TextColor="White"
                Clicked="OnFavoriteClicked"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="16"/>

    </Grid>

</ContentPage>