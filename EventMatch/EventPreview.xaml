<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EventMatch.EventPreview"
             Title="ReviewEvents">
    
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="12">
                <Label Text="Events" FontSize="18" TextColor="#A259FF" HorizontalOptions="Center" />

                <!-- Single event preview -->
                <Frame HasShadow="False" CornerRadius="8" BackgroundColor="#333333" Padding="0" Margin="0,8">
                    <VerticalStackLayout Padding="12" Spacing="8">
                        <Frame HasShadow="False" CornerRadius="8" BackgroundColor="#333333" HeightRequest="420" HorizontalOptions="Fill">
                            <Grid>
                                <Image x:Name="EventImage" Source="image-placeholder.png" Aspect="AspectFill" />
                            </Grid>
                        </Frame>

                        <Label Text="Event description" FontSize="12" TextColor="#D8BFD8" />
                        <Label x:Name="EventDetailsLabel" HeightRequest="120" BackgroundColor="#80232323" TextColor="White" VerticalTextAlignment="Start" Padding="8" />
                        <Label x:Name="CreatedAtLabel" FontSize="10" TextColor="#D8BFD8" HorizontalOptions="End" />
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Circular 'x' button overlay to cycle events -->
        <Button x:Name="CycleEventButton" Text="x" WidthRequest="44" HeightRequest="44" CornerRadius="22" BackgroundColor="#AA000000" TextColor="White" FontAttributes="Bold" FontSize="18" Clicked="OnCycleEventClicked" HorizontalOptions="End" VerticalOptions="Start" Margin="16" />

        <!-- Favorite heart button -->
        <Button x:Name="FavoriteButton" Text="♥" WidthRequest="48" HeightRequest="48" CornerRadius="24" BackgroundColor="#AA00AA00" TextColor="White" FontAttributes="Bold" FontSize="18" Clicked="OnFavoriteClicked" HorizontalOptions="End" VerticalOptions="End" Margin="16" />
    </Grid>
</ContentPage>