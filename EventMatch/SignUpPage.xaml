<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EventMatch.SignUpPage"
             Shell.FlyoutBehavior="Disabled"
             Shell.NavBarIsVisible="False"
             BackgroundImageSource="purplebackg.jpg"
             Title="Sign Up">
    <ScrollView>
        <Grid RowDefinitions="*,Auto,*" ColumnDefinitions="*">
            <VerticalStackLayout Grid.Row="1" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="400" Spacing="24" Padding="0">
                <Label Text="EventMatch" FontSize="40" TextColor="#D8BFD8" HorizontalOptions="Center" FontFamily="Segoe UI Semibold"/>
                <Border Background="Transparent" StrokeThickness="0" StrokeShape="RoundRectangle 20" Padding="32">
                    <VerticalStackLayout Spacing="18">
                        <Label Text="Create account" FontSize="22" TextColor="#D8BFD8" HorizontalOptions="Center" FontFamily="Segoe UI Semibold"/>
                        <Label Text="Sign up to get started" FontSize="14" TextColor="#b0b0b0" HorizontalOptions="Center" FontFamily="Segoe UI Semibold"/>
                        <Entry x:Name="EmailEntry" Placeholder="Email" BackgroundColor="#80232323" TextColor="White" PlaceholderColor="White" HeightRequest="44" Margin="0,10,0,0"/>
                        <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" BackgroundColor="#80232323" TextColor="White" PlaceholderColor="White" HeightRequest="44"/>
                        <Entry x:Name="ConfirmPasswordEntry" Placeholder="Confirm Password" IsPassword="True" BackgroundColor="#80232323" TextColor="White" PlaceholderColor="White" HeightRequest="44"/>
                        <Button Text="Sign up" BackgroundColor="#A259FF" TextColor="#D8BFD8" FontAttributes="Bold" CornerRadius="8" HeightRequest="48" Clicked="OnSignUpClicked"/>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                            <Label Text="Already have an account?" FontSize="13" TextColor="White" FontFamily="Segoe UI Semibold"/>
                            <Label Text="Sign in" FontSize="13" TextColor="#A259FF" FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSignInTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
