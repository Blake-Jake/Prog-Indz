<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EventMatch.EditGroupPage"
             Title="Edit Group">
    <StackLayout Padding="20" Spacing="12">
        <Label Text="Edit Group" FontSize="20" HorizontalOptions="Center" />

        <Label Text="Name" />
        <Entry x:Name="NameEntry" Placeholder="Group name" />

        <Label Text="Description" />
        <Editor x:Name="DescriptionEditor" HeightRequest="100" />

        <StackLayout Orientation="Horizontal" Spacing="12">
            <Button Text="Save" Clicked="OnSaveClicked" HorizontalOptions="FillAndExpand" />
            <Button Text="Cancel" Clicked="OnCancelClicked" HorizontalOptions="FillAndExpand" />
        </StackLayout>
    </StackLayout>
</ContentPage>
