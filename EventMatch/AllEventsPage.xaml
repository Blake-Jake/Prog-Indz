<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EventMatch.AllEventsPage"
             Title="All Events">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label Text="All Events" FontSize="20" TextColor="#A259FF" HorizontalOptions="Center" />

            <CollectionView x:Name="AllEventsCollectionView" ItemsLayout="VerticalList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame HasShadow="False" CornerRadius="8" BackgroundColor="#333333" Padding="12" Margin="0,8">
                            <VerticalStackLayout>
                                <Image Source="{Binding ImageSource}" Aspect="AspectFill" HeightRequest="220" />
                                <Label Text="{Binding Details}" FontSize="14" TextColor="White" Margin="0,8,0,0" />
                                <Label Text="{Binding CreatedAt}" FontSize="10" TextColor="#D8BFD8" HorizontalOptions="End" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
