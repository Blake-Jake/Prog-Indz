<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EventMatch.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:EventMatch"
    x:Name="MyAppShell"
    Title="EventMatch">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate local:LoginPage}"
        Route="LoginPage" x:Name="MyLoginPage"
        FlyoutItemIsVisible="False"/>
    <ShellContent
        Title="Sign Up"
        ContentTemplate="{DataTemplate local:SignUpPage}"
        Route="SignUpPage" />
    <ShellContent x:Name="MyDashboardPage"
        Title="Home"
        ContentTemplate="{DataTemplate local:DashboardPage}"
        Route="DashboardPage" />
    
    <MenuItem 
        Text="Logout" 
        Clicked="OnLogoutClicked"/>

</Shell>
