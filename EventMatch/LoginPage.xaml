<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EventMatch.LoginPage"
             BackgroundColor="#181818"
             Title="Login">
    <ScrollView>
        <Grid RowDefinitions="*,Auto,*" ColumnDefinitions="*">
            <VerticalStackLayout Grid.Row="1" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="400" Spacing="24" Padding="0">
                <Label Text="EventMatch" FontSize="32" FontAttributes="Bold" TextColor="#A259FF" HorizontalOptions="Center"/>
                <Border Background="#232323" StrokeThickness="0" StrokeShape="RoundRectangle 20" Padding="32">
                    <VerticalStackLayout Spacing="18">
                        <Label Text="Welcome back" FontSize="22" TextColor="White" HorizontalOptions="Center"/>
                        <Label Text="Sign in to continue to your account" FontSize="14" TextColor="#b0b0b0" HorizontalOptions="Center"/>
                        <Entry x:Name="EmailEntry" Placeholder="Email" BackgroundColor="#232323" TextColor="White" PlaceholderColor="#888" HeightRequest="44" Margin="0,10,0,0">
                            <Entry.Shadow>
                                <Shadow Brush="#232323" Offset="0,2" Radius="4"/>
                            </Entry.Shadow>
                        </Entry>
                        <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" BackgroundColor="#232323" TextColor="White" PlaceholderColor="#888" HeightRequest="44">
                            <Entry.Shadow>
                                <Shadow Brush="#232323" Offset="0,2" Radius="4"/>
                            </Entry.Shadow>
                        </Entry>
                        <Button Text="Sign in" BackgroundColor="#A259FF" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="48" Clicked="OnSignInClicked"/>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                            <Label Text="Don't have an account?" FontSize="13" TextColor="#b0b0b0"/>
                            <Label Text="Sign up" FontSize="13" TextColor="#A259FF" FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSignUpTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
