<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EventMatch.ProfilePage"
             Shell.FlyoutBehavior="Disabled"
             Shell.NavBarIsVisible="False"
             BackgroundImageSource="purplebackg.jpg"
             Title="Profile">

    <ScrollView>
        <Grid RowDefinitions="*,Auto,*" ColumnDefinitions="*">
            <Image Source="loginBackground.jpg" Aspect="AspectFill" />

            <VerticalStackLayout Grid.Row="1" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="400" Spacing="18" Padding="24">
                <Label Text="Profile" FontSize="36" FontFamily="Segoe UI Semibold" TextColor="#D8BFD8" HorizontalOptions="Center"/>

                <Border Background="Transparent" StrokeThickness="0" StrokeShape="RoundRectangle 20" Padding="18"/>

                <VerticalStackLayout Spacing="12">
                    <Entry x:Name="UsernameEntry"
                           Placeholder="Username"
                           BackgroundColor="#80232323"
                           TextColor="White"
                           PlaceholderColor="White"
                           HeightRequest="44" />

                    <Entry x:Name="TagEntry"
                           Placeholder="#tag"
                           BackgroundColor="#80232323"
                           TextColor="White"
                           PlaceholderColor="White"
                           HeightRequest="44" />

                    <Picker x:Name="RadiusPicker"
                            Title="Area (km)"
                            BackgroundColor="#80232323"
                            TextColor="White"
                            HeightRequest="60">
                        <Picker.Items>
                            <x:String>10</x:String>
                            <x:String>25</x:String>
                            <x:String>50</x:String>
                            <x:String>100</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label Text="Profile description" FontSize="14" TextColor="#D8BFD8" FontFamily="Segoe UI Semibold"/>
                    <Editor x:Name="DescriptionEditor"
                            BackgroundColor="#80232323"
                            TextColor="White"
                            Placeholder="Tell others about yourself..."
                            HeightRequest="120" />

                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Center">
                        <Frame Padding="0" HasShadow="False" CornerRadius="80" HeightRequest="120" WidthRequest="120" BackgroundColor="#333333">
                            <Image x:Name="ProfileImage" Source="profile-placeholder.png" Aspect="AspectFill" />
                        </Frame>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="8">
                            <Button x:Name="AddPhotoButton" Text="Add Photo" BackgroundColor="#A259FF" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="44" Clicked="OnAddPhotoClicked"/>
                            <Label Text="Supported formats: JPG, PNG" FontSize="12" TextColor="#D8BFD8" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Button Text="Back" BackgroundColor="#333333" TextColor="White" CornerRadius="8" HeightRequest="48" WidthRequest="110" Clicked="OnBackClicked"/>
                    <Button Text="Friends" BackgroundColor="#A259FF" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="48" WidthRequest="110" Clicked="OnFriendsClicked"/>
                    <Button Text="Save" BackgroundColor="#2E8B57" TextColor="White" CornerRadius="8" HeightRequest="48" WidthRequest="110" Clicked="OnSaveClicked"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>